---
// Sample review data - you can replace this with dynamic data later
const reviews = [
  {
    id: 1,
    name: "David",
    role: "Homeowner",
    rating: 5,
    text: "At vero eos et accusamus et iusto odio dignissimos ducimus qui blanditiis praesentium voluptatum deleniti atque corrupti quos dolores et quas molestias excepturi sint occaecati cupiditate non provident.",
    avatar: "/public/favicon.svg" // placeholder avatar
  }
];

const stats = {
  projectsDone: "5634+",
  overallRating: "4.9",
  totalReviews: "2555"
};
---

<section class="reviews-section bg-[#1e293b] py-16 md:py-24 relative overflow-hidden">
  <!-- Background Pattern -->
  <div class="absolute inset-0 opacity-10">
    <div class="absolute top-10 left-10 text-6xl font-bold text-white/20 transform -rotate-12">REVIEWS</div>
    <div class="absolute bottom-20 right-20 text-4xl font-bold text-white/20 transform rotate-12">★★★★★</div>
  </div>

  <div class="container-custom px-4 relative z-10">
    <div class="grid lg:grid-cols-2 gap-12 items-center">
      
      <!-- Left Side - Image and Stats -->
      <div class="relative">
        <!-- Worker Image Placeholder -->
        <div class="relative bg-gradient-to-br from-[#F5A623] to-[#DC2626] rounded-2xl p-8 mb-6">
          <div class="bg-white/90 rounded-xl p-6 text-center">
            <div class="w-32 h-32 bg-[#2563EB] rounded-full mx-auto mb-4 flex items-center justify-center">
              <span class="text-white text-4xl font-bold">👷</span>
            </div>
            <p class="text-[#334155] font-semibold">Professional Tradesperson</p>
          </div>
        </div>

        <!-- Projects Counter -->
        <div class="absolute -top-4 -right-4 bg-[#F5A623] text-[#334155] px-6 py-3 rounded-xl shadow-lg">
          <div class="text-2xl font-bold">{stats.projectsDone}</div>
          <div class="text-sm font-medium">PROJECTS DONE</div>
        </div>

        <!-- Rating Card -->
        <div class="bg-white rounded-xl p-6 shadow-lg max-w-xs">
          <div class="flex items-center gap-4">
            <div class="text-3xl font-bold text-[#334155]">{stats.overallRating}</div>
            <div>
              <div class="text-[#334155] font-semibold">Overall Rating</div>
              <div class="text-[#64748B] text-sm">Based on {stats.totalReviews} Reviews</div>
            </div>
          </div>
        </div>
      </div>

      <!-- Right Side - Review Content -->
      <div class="text-white">
        {reviews.map((review) => (
          <div class="review-card">
            <!-- Quote -->
            <div class="mb-8">
              <span class="text-6xl text-[#F5A623] font-serif leading-none">"</span>
              <p class="text-lg md:text-xl leading-relaxed font-light italic mt-4">
                {review.text}
              </p>
              <span class="text-6xl text-[#F5A623] font-serif leading-none float-right">"</span>
            </div>

            <!-- Reviewer Info -->
            <div class="flex items-center gap-4 mt-8">
              <div class="w-12 h-12 bg-[#2563EB] rounded-full flex items-center justify-center">
                <span class="text-white font-bold text-lg">{review.name.charAt(0)}</span>
              </div>
              <div>
                <div class="font-semibold text-lg">{review.name}</div>
                <div class="text-[#64748B] text-sm">{review.role}</div>
              </div>
              <div class="ml-auto">
                <!-- Star Rating -->
                <div class="flex gap-1">
                  {Array.from({ length: review.rating }, (_, i) => (
                    <span class="text-[#F5A623] text-xl">★</span>
                  ))}
                </div>
              </div>
            </div>
          </div>
        ))}

        <!-- Navigation Arrows -->
        <div class="flex gap-4 mt-8">
          <button class="w-12 h-12 bg-white/20 hover:bg-white/30 rounded-full flex items-center justify-center transition-colors duration-200">
            <span class="text-white text-xl">←</span>
          </button>
          <button class="w-12 h-12 bg-white/20 hover:bg-white/30 rounded-full flex items-center justify-center transition-colors duration-200">
            <span class="text-white text-xl">→</span>
          </button>
        </div>
      </div>
    </div>
  </div>
</section>

<style>
  .reviews-section {
    font-family: var(--font-primary);
  }
  
  .review-card {
    position: relative;
  }
  
  /* Responsive adjustments */
  @media (max-width: 1024px) {
    .reviews-section .grid {
      grid-template-columns: 1fr;
      gap: 2rem;
    }
    
    .reviews-section .absolute.-top-4.-right-4 {
      position: relative;
      top: 0;
      right: 0;
      margin: 1rem auto;
      width: fit-content;
    }
  }
  
  /* Animation for quote marks */
  .review-card .text-6xl {
    animation: fadeIn 0.6s ease-in-out;
  }
  
  @keyframes fadeIn {
    from { opacity: 0; transform: scale(0.8); }
    to { opacity: 1; transform: scale(1); }
  }
</style>