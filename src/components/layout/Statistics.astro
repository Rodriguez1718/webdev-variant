---
---

<section class="statistics-section bg-white py-16 md:py-24 relative overflow-hidden" style="font-family: 'Poppins', sans-serif;">
  <div class="container mx-auto px-4 relative z-10">
    
    <!-- Main Layout - Image Left, Content Right -->
    <div class="grid lg:grid-cols-2 gap-12 items-center max-w-6xl mx-auto">
      
      <!-- Left Side - Image with Stats Card -->
      <div class="relative">
        <!-- Main Image -->
        <div class="relative rounded-2xl overflow-hidden shadow-xl">
          <img 
            src="https://images.unsplash.com/photo-1552664730-d307ca884978?ixlib=rb-4.0.3&ixid=M3wxMjA3fDB8MHxwaG90by1wYWdlfHx8fGVufDB8fHx8fA%3D%3D&auto=format&fit=crop&w=800&q=80"
            alt="Professional contractor"
            class="w-full h-96 object-cover"
          />
        </div>

        <!-- Blue Stats Card - Overlaid -->
        <div class="absolute -top-6 -right-6 bg-[#2563EB] text-white rounded-2xl p-6 shadow-xl max-w-xs">
          <div class="text-5xl font-black mb-2" style="font-family: 'Poppins', sans-serif;">
            50k+
          </div>
          <div class="text-sm font-semibold uppercase tracking-wide" style="font-family: 'Poppins', sans-serif;">
            Experienced<br>Working
          </div>
        </div>

        <!-- Google Reviews Card - Bottom Left -->
        <div class="absolute -bottom-6 -left-6 bg-white rounded-2xl p-4 shadow-xl max-w-xs">
          <div class="flex items-center gap-3 mb-3">
            <div class="flex -space-x-2">
              <img src="https://images.unsplash.com/photo-1507003211169-0a1dd7228f2d?ixlib=rb-4.0.3&w=100&q=80" alt="Review 1" class="w-8 h-8 rounded-full border-2 border-white" />
              <img src="https://images.unsplash.com/photo-1494790108755-2616b612b786?ixlib=rb-4.0.3&w=100&q=80" alt="Review 2" class="w-8 h-8 rounded-full border-2 border-white" />
              <img src="https://images.unsplash.com/photo-1438761681033-6461ffad8d80?ixlib=rb-4.0.3&w=100&q=80" alt="Review 3" class="w-8 h-8 rounded-full border-2 border-white" />
            </div>
            <div class="text-2xl font-bold text-[#f39c12]" style="font-family: 'Poppins', sans-serif;">
              Google
            </div>
          </div>
          <div class="flex items-center gap-2 mb-2">
            <div class="text-2xl font-bold text-[#334155]" style="font-family: 'Poppins', sans-serif;">
              4.8
            </div>
            <div class="flex gap-1">
              {Array.from({ length: 5 }, (_, i) => (
                <span class="text-[#f39c12] text-lg">★</span>
              ))}
            </div>
          </div>
          <div class="text-sm text-[#64748B]" style="font-family: 'Poppins', sans-serif;">
            From 799+ reviews
          </div>
        </div>
      </div>

      <!-- Right Side - Content -->
      <div>
        <!-- Section Label -->
        <div class="text-[#2563EB] font-semibold text-sm uppercase tracking-wide mb-4" style="font-family: 'Poppins', sans-serif;">
          About Our Company
        </div>

        <!-- Main Heading -->
        <h2 class="text-4xl lg:text-5xl font-bold text-[#334155] mb-6 leading-tight" style="font-family: 'Poppins', sans-serif;">
          We ensure your comfort and safety
        </h2>

        <!-- Description -->
        <p class="text-[#64748B] text-lg mb-8 leading-relaxed" style="font-family: 'Poppins', sans-serif;">
          We help define your identity and care approach through tailored for strategies.
        </p>

        <!-- Tabs -->
        <div class="flex gap-4 mb-8 border-b border-[#e5e7eb]">
          <button class="px-4 py-3 font-semibold text-white bg-[#2563EB] rounded-t-lg transition-colors" style="font-family: 'Poppins', sans-serif;">
            About Us
          </button>
          <button class="px-4 py-3 font-semibold text-[#334155] border-b-2 border-[#2563EB] hover:text-[#2563EB] transition-colors" style="font-family: 'Poppins', sans-serif;">
            Our Mission
          </button>
          <button class="px-4 py-3 font-semibold text-[#334155] border-b-2 border-transparent hover:text-[#2563EB] transition-colors" style="font-family: 'Poppins', sans-serif;">
            Our History
          </button>
        </div>

        <!-- Tab Content -->
        <p class="text-[#64748B] mb-8 leading-relaxed" style="font-family: 'Poppins', sans-serif;">
          Helping individuals and families regain control of their financial future by repairing and improving their credit scores team of the experts is dedicated to analyzing your credit report.
        </p>

        <!-- Features Grid -->
        <div class="grid grid-cols-2 gap-6 mb-8">
          <div class="flex items-start gap-3">
            <div class="text-[#2563EB] text-2xl mt-1">✓</div>
            <div>
              <div class="font-semibold text-[#334155]" style="font-family: 'Poppins', sans-serif;">
                Secure Transactions
              </div>
            </div>
          </div>
          <div class="flex items-start gap-3">
            <div class="text-[#2563EB] text-2xl mt-1">✓</div>
            <div>
              <div class="font-semibold text-[#334155]" style="font-family: 'Poppins', sans-serif;">
                User-Friendly Interface
              </div>
            </div>
          </div>
          <div class="flex items-start gap-3">
            <div class="text-[#2563EB] text-2xl mt-1">✓</div>
            <div>
              <div class="font-semibold text-[#334155]" style="font-family: 'Poppins', sans-serif;">
                Innovative Solutions
              </div>
            </div>
          </div>
          <div class="flex items-start gap-3">
            <div class="text-[#2563EB] text-2xl mt-1">✓</div>
            <div>
              <div class="font-semibold text-[#334155]" style="font-family: 'Poppins', sans-serif;">
                Real-Time Analytics
              </div>
            </div>
          </div>
        </div>

        <!-- CTA Buttons -->
        <div class="flex flex-col sm:flex-row items-center gap-4">
          <button class="bg-[#2563EB] text-white px-8 py-3 rounded-lg font-semibold hover:bg-[#1d4ed8] transition-colors flex items-center gap-2" style="font-family: 'Poppins', sans-serif;">
            Get Started Now
            <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 7l5 5m0 0l-5 5m5-5H6"></path>
            </svg>
          </button>
          <button class="bg-[#2563EB] text-white px-6 py-3 rounded-full hover:bg-[#1d4ed8] transition-colors flex items-center justify-center" style="font-family: 'Poppins', sans-serif;">
            <svg class="w-6 h-6" fill="currentColor" viewBox="0 0 24 24">
              <path d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z"></path>
            </svg>
          </button>
          <div class="text-[#334155]" style="font-family: 'Poppins', sans-serif;">
            <div class="font-semibold">Call Us 24/7</div>
            <div class="text-lg font-bold text-[#2563EB]">+00 (47) 939 4888</div>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>

<style>
  .statistics-section {
    font-family: 'Poppins', sans-serif;
  }

  .statistics-section * {
    font-family: 'Poppins', sans-serif !important;
  }

  /* Responsive adjustments */
  @media (max-width: 1024px) {
    .statistics-section .grid {
      grid-template-columns: 1fr;
      gap: 2rem;
    }

    .statistics-section .absolute {
      position: relative;
      top: auto !important;
      right: auto !important;
      left: auto !important;
      bottom: auto !important;
      margin-top: 1rem;
    }
  }

  /* Smooth transitions */
  .statistics-section button {
    transition: all 0.3s ease;
  }

  .statistics-section button:hover {
    transform: translateY(-2px);
  }
</style>